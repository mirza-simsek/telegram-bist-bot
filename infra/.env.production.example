TELEGRAM_BOT_TOKEN=123456:replace-me
TELEGRAM_CHAT_ID=

# Optional: if empty, TELEGRAM_CHAT_ID is allowed. Comma separated.
TELEGRAM_ALLOWED_CHAT_IDS=

MARKET_TIMEZONE=Europe/Istanbul
ALL_SYMBOLS_FILE=data/bist_tum_hisseler.txt
BIST100_SYMBOLS_FILE=data/bist_100_hisseler.txt
DEFAULT_UNIVERSE=tum
SCHEDULED_UNIVERSE=tum

TRADINGVIEW_CHART_CONCURRENCY=4
PYTHON_SCANNER_ENABLED=true
PYTHON_EXECUTABLE=python3
PYTHON_SCANNER_SCRIPT=scripts/bist_data_scrap_bridge.py
PYTHON_SCANNER_BATCH_SIZE=50
PYTHON_SCANNER_WORKERS=4
PYTHON_SCANNER_YF_THREADS=false
HTTP_TIMEOUT_SECONDS=8
SCAN_TIMEOUT_MINUTES=12
MAX_RESULTS=10

# Command filters.
GUNLUK_MIN_SCORE=3
GUNICI_MIN_SCORE=5

# Scheduled alert filters.
GUNLUK_ALERT_MIN_SCORE=3
GUNICI_ALERT_MIN_SCORE=7
ALERT_DEDUP_HOURS=6

# Weekday schedule in MARKET_TIMEZONE.
INTRADAY_AUTO_ENABLED=true
INTRADAY_START_HOUR=10
INTRADAY_END_HOUR=17
INTRADAY_SCAN_MINUTE=15

DAILY_AUTO_ENABLED=true
DAILY_SCAN_HOUR=18
DAILY_SCAN_MINUTE=20

RUN_SCAN_ON_STARTUP=false
